# Use a local or cloud (MongoDB Atlas) connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/reimbursement_manager?retryWrites=true&w=majority

# Port for the Express server to listen on
PORT=8000
NODE_ENV=development

# JSON Web Token Secret (used for signing and verifying tokens)
# Generate a random string (e.g., using `require('crypto').randomBytes(64).toString('hex')`)
JWT_SECRET=your_super_secret_jwt_key_here

# Currency Exchange API Key (from exchangerate-api.com)
# Used to convert foreign currencies to company default currency
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# SMTP Configuration
# If these are left blank, Ethereal mock emails will be used automatically
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your actual email address
SMTP_USER=your_email@gmail.com

# 16-character App Password (NOT your standard account password)
SMTP_PASS=your_16_digit_app_password
